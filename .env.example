PUBLIC_EMAILJS_SERVICE_ID=service_id
PUBLIC_EMAILJS_TEMPLATE_ID=template_id
PUBLIC_EMAILJS_PUBLIC_KEY=public_key

PUBLIC_SANITY_PROJECT_ID=project_id
PUBLIC_SANITY_DATASET=production

# Required for the client review submission form
# Create a token in Sanity → Manage → API → Tokens with "Editor" permissions
SANITY_WRITE_TOKEN=sanity_write_token

# Secret token that protects the review form — include in the URL: /review?t=YOUR_TOKEN
# Use any random string
REVIEW_ACCESS_TOKEN=your_review_access_token
