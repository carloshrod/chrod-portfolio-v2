---
import ReviewForm from "../components/ui/ReviewForm.tsx";
import "../styles/global.css";
import { useTranslations } from "../i18n/utils";

export const prerender = false;

const lang = "en" as const;
const t = useTranslations(lang);
const token = Astro.url.searchParams.get("t") ?? "";
const validToken = import.meta.env.REVIEW_ACCESS_TOKEN;
const isValid = Boolean(validToken && token === validToken);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Leave a review — CHRod</title>
    <link rel="icon" type="image/png" href="/chrod-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#06060c] text-slate-200 antialiased min-h-screen">
    <div class="min-h-screen flex flex-col">
      <!-- Header -->
      <header class="border-b border-slate-800/60 py-4 px-6">
        <div class="max-w-2xl mx-auto flex items-center justify-between">
          <a href="/" class="flex items-center gap-2.5 group">
            <img
              src="/chrod-logo.png"
              alt="CHRod"
              class="h-10 w-auto opacity-90 group-hover:opacity-100 transition"
            />
          </a>
          <div
            class="flex items-center rounded-full border border-border bg-surface-alt text-xs font-semibold overflow-hidden"
          >
            <a
              href={`/review${token ? `?t=${encodeURIComponent(token)}` : ""}`}
              class="px-3 py-1 transition-colors bg-surface-raised text-red-400"
              aria-label="Switch to English">EN</a
            ><a
              href={`/es/review${token ? `?t=${encodeURIComponent(token)}` : ""}`}
              class="px-3 py-1 transition-colors text-slate-400 hover:text-slate-200"
              aria-label="Cambiar a Español">ES</a
            >
          </div>
        </div>
      </header>

      <!-- Main -->
      <main class="flex-1 py-12 px-6">
        <div class="max-w-2xl mx-auto">
          <!-- Page heading -->
          <div class="mb-10 text-center">
            <div
              class="inline-flex items-center gap-2 text-xs font-medium text-accent-light bg-accent/10 border border-accent/20 rounded-full px-3 py-1 mb-4"
            >
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
                <path
                  d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                ></path>
              </svg>
              {t("review.badge")}
            </div>
            <h1
              class="text-3xl sm:text-4xl font-bold text-white tracking-tight mb-3"
            >
              {t("review.heading")}
            </h1>
            <p class="text-slate-400 leading-relaxed max-w-md mx-auto">
              {t("review.subtitle")}
            </p>
          </div>

          <!-- Card -->
          <div
            class="rounded-2xl border border-border bg-surface p-6 sm:p-8 shadow-xl shadow-black/30"
          >
            {
              isValid ? (
                <ReviewForm lang="en" token={token} client:load />
              ) : (
                <div class="flex flex-col items-center justify-center text-center py-16 px-4">
                  <div class="w-14 h-14 rounded-full bg-red-500/10 flex items-center justify-center mb-5">
                    <svg
                      class="w-7 h-7 text-red-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
                      />
                    </svg>
                  </div>
                  <h2 class="text-xl font-semibold text-white mb-2">
                    {t("review.invalid.heading")}
                  </h2>
                  <p class="text-slate-500 text-sm max-w-xs">
                    {t("review.invalid.body")}
                  </p>
                </div>
              )
            }
          </div>
        </div>
      </main>

      <!-- Footer -->
      <footer class="border-t border-slate-800/60 py-5 px-6 text-center">
        <p class="text-slate-600 text-xs">
          &copy; {new Date().getFullYear()} CHRod · <a
            href="/"
            class="hover:text-slate-400 transition">chrod.dev</a
          >
        </p>
      </footer>
    </div>
  </body>
</html>
