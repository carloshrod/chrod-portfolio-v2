---
import WhatsAppButton from "../components/ui/WhatsAppButton.astro";
import "../styles/global.css";
import type { Locale } from "../i18n/ui";

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  lang?: Locale;
  canonicalUrl?: string;
}

const {
  title = "CHRod - Web Developer",
  description = "Full-stack web developer specializing in React, Node.js & modern web technologies. Available for freelance projects — landing pages, web apps, e-commerce & API development.",
  keywords = "web developer, full-stack developer, React, Node.js, freelance, portfolio, landing pages, web apps, e-commerce",
  lang = "en",
  canonicalUrl,
} = Astro.props;

const siteUrl = "https://chrod.dev";
const canonical = canonicalUrl ?? `${siteUrl}${Astro.url.pathname}`;
const ogImage = `${siteUrl}/chrod-logo.png`;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Carlos Hernández - CHRod" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#06060c" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- hreflang -->
    <link rel="alternate" hreflang="en" href={siteUrl} />
    <link rel="alternate" hreflang="es" href={`${siteUrl}/es`} />
    <link rel="alternate" hreflang="x-default" href={siteUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="CHRod - Web Developer" />
    <meta property="og:site_name" content="CHRod" />
    <meta property="og:locale" content={lang === "es" ? "es_CO" : "en_US"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/png" href="/chrod-logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#06060c] text-slate-200 antialiased">
    <slot />

    <!-- WhatsApp floating button -->
    <WhatsAppButton lang={lang} />
  </body>
</html>
