---
import WhatsAppButton from "../components/ui/WhatsAppButton.astro";
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "chrod — Developer Portfolio",
  description = "Full-stack developer portfolio showcasing projects, skills and experience.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/chrod-logo.png" />
    <link rel="icon" href="/chrod-logo.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#06060c] text-slate-200 antialiased">
    <slot />

    <!-- WhatsApp floating button -->
    <WhatsAppButton />
  </body>
</html>
