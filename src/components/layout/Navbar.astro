---
import { Image } from "astro:assets";
import logo from "../../assets/chrod-logo.png";
import Container from "./Container.astro";

const navLinks = [
  { href: "#about", label: "About" },
  { href: "#skills", label: "Skills" },
  { href: "#projects", label: "Projects" },
  { href: "#reviews", label: "Testimonials" },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-border bg-[#080808]/80 backdrop-blur-md"
>
  <Container>
    <nav class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2" aria-label="Home">
        <Image
          src={logo}
          alt="chrod logo"
          loading="eager"
          class="h-10 w-auto"
        />
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-8 md:flex">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium text-slate-400 transition-colors hover:text-red-400"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Contact button (desktop) -->
      <button
        id="navbar-contact-btn"
        class="hidden rounded-lg border border-red-600/50 px-4 py-1.5 text-sm font-medium text-red-400 transition-all hover:border-red-400 hover:text-red-300 cursor-pointer md:block"
      >
        Contact
      </button>

      <!-- Mobile menu toggle -->
      <button
        id="mobile-menu-toggle"
        class="flex items-center rounded-md p-2 text-slate-400 transition-colors hover:text-red-400 md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          id="icon-menu"
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          id="icon-close"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </nav>
  </Container>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <Container>
      <ul class="flex flex-col gap-1 py-4">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="mobile-nav-link block rounded-md px-3 py-2 text-center text-sm font-medium text-slate-400 transition-colors hover:bg-border hover:text-red-400"
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="pt-2">
          <button
            id="mobile-contact-btn"
            class="mobile-nav-link w-full rounded-lg border border-red-600/50 px-3 py-2 text-center text-sm font-medium text-red-400 transition-all hover:border-red-400 cursor-pointer"
          >
            Contact
          </button>
        </li>
      </ul>
    </Container>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    iconMenu?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  const openDrawer = () => {
    document.dispatchEvent(new CustomEvent("open-contact-drawer"));
    // Close mobile menu if open
    menu?.classList.add("hidden");
    iconMenu?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
    toggle?.setAttribute("aria-expanded", "false");
  };

  document
    .getElementById("navbar-contact-btn")
    ?.addEventListener("click", openDrawer);
  document
    .getElementById("mobile-contact-btn")
    ?.addEventListener("click", openDrawer);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });
</script>
