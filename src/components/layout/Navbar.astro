---
import { Image } from "astro:assets";
import logo from "../../assets/chrod-logo.png";
import Container from "./Container.astro";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";
import Icon from "../ui/icons.astro";

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);
const homeUrl = lang === "es" ? "/es" : "/";

const navLinks = [
  { href: "#about", label: t("nav.about") },
  { href: "#services", label: t("nav.services") },
  { href: "#skills", label: t("nav.skills") },
  { href: "#projects", label: t("nav.projects") },
  { href: "#reviews", label: t("nav.testimonials") },
];
---

<header
  class="fixed inset-x-0 top-0 z-50 border-b border-border bg-[#080808]/80 backdrop-blur-md"
>
  <Container>
    <nav class="grid h-16 grid-cols-[auto_1fr_auto] items-center">
      <a
        href={homeUrl}
        id="navbar-logo-link"
        class="flex items-center gap-2"
        aria-label="Home"
      >
        <Image
          src={logo}
          alt="chrod logo"
          loading="eager"
          class="h-10 w-auto"
        />
      </a>

      <!-- Desktop nav links (centered) -->
      <ul class="hidden items-center justify-center gap-8 md:flex">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                data-nav-link={link.href}
                class="nav-link text-sm font-medium text-slate-400 transition-colors hover:text-red-400 active:text-red-400"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <!-- Desktop right: lang switcher + contact -->
      <div class="hidden items-center gap-3 md:flex">
        <div
          class="flex items-center rounded-full border border-border bg-surface-alt text-xs font-semibold overflow-hidden"
        >
          <a
            href="/"
            data-lang-link="en"
            class={`px-3 py-1 transition-colors ${
              lang === "en"
                ? "bg-surface-raised text-red-400"
                : "text-slate-400 hover:text-slate-200"
            }`}
            aria-label="Switch to English">EN</a
          >
          <a
            href="/es"
            data-lang-link="es"
            class={`px-3 py-1 transition-colors ${
              lang === "es"
                ? "bg-surface-raised text-red-400"
                : "text-slate-400 hover:text-slate-200"
            }`}
            aria-label="Cambiar a Español">ES</a
          >
        </div>
        <button
          id="navbar-contact-btn"
          class="rounded-lg border border-red-600/50 px-4 py-1.5 text-sm font-medium text-red-400 transition-all hover:border-red-400 hover:text-red-300 cursor-pointer"
        >
          {t("nav.contact")}
        </button>
      </div>

      <!-- Mobile right: lang switcher + hamburger -->
      <div class="flex justify-end items-center gap-3 md:hidden">
        <div
          class="flex items-center rounded-full border border-border bg-surface-alt text-xs font-semibold overflow-hidden"
        >
          <a
            href="/"
            data-lang-link="en"
            class={`px-3 py-1 transition-colors ${
              lang === "en"
                ? "bg-surface-raised text-red-400"
                : "text-slate-400 hover:text-slate-200"
            }`}
            aria-label="Switch to English">EN</a
          >
          <a
            href="/es"
            data-lang-link="es"
            class={`px-3 py-1 transition-colors ${
              lang === "es"
                ? "bg-surface-raised text-red-400"
                : "text-slate-400 hover:text-slate-200"
            }`}
            aria-label="Cambiar a Español">ES</a
          >
        </div>

        <!-- Mobile: hamburger -->
        <button
          id="mobile-menu-toggle"
          class="flex items-center justify-end rounded-md p-2 text-slate-400 transition-colors hover:text-red-400 cursor-pointer md:hidden"
          aria-label="Toggle menu"
          aria-expanded="false"
        >
          <Icon name="menu" id="icon-menu" />
          <Icon name="close" class="hidden" id="icon-close" />
        </button>
      </div>
    </nav>
  </Container>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border md:hidden">
    <Container>
      <ul class="flex flex-col gap-1 py-4">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                data-nav-link={link.href}
                class="mobile-nav-link block rounded-md px-3 py-2 text-center text-sm font-medium text-slate-400 transition-colors hover:bg-border hover:text-red-400 active:bg-border active:text-red-400"
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="pt-2">
          <div class="flex items-center">
            <button
              id="mobile-contact-btn"
              class="flex-1 rounded-lg border border-red-600/50 px-3 py-2 text-center text-sm font-medium text-red-400 transition-all hover:border-red-400 active:border-red-400 cursor-pointer"
            >
              {t("nav.contact")}
            </button>
          </div>
        </li>
      </ul>
    </Container>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    iconMenu?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  const openDrawer = () => {
    document.dispatchEvent(new CustomEvent("open-contact-drawer"));
    // Close mobile menu if open
    menu?.classList.add("hidden");
    iconMenu?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
    toggle?.setAttribute("aria-expanded", "false");
  };

  document
    .getElementById("navbar-contact-btn")
    ?.addEventListener("click", openDrawer);
  document
    .getElementById("mobile-contact-btn")
    ?.addEventListener("click", openDrawer);

  mobileLinks.forEach((link) => {
    link.addEventListener("click", () => {
      menu?.classList.add("hidden");
      iconMenu?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    });
  });

  // Active section highlighting
  const navLinks =
    document.querySelectorAll<HTMLAnchorElement>("a[data-nav-link]");
  const sectionIds = Array.from(navLinks).map((a) =>
    a.getAttribute("data-nav-link")!.replace("#", ""),
  );
  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];

  const visibleSections = new Map<string, boolean>();
  sections.forEach((s) => visibleSections.set(s.id, false));

  const langLinks =
    document.querySelectorAll<HTMLAnchorElement>("a[data-lang-link]");

  function updateLangLinks(hash: string) {
    langLinks.forEach((a) => {
      const lang = a.getAttribute("data-lang-link");
      const base = lang === "es" ? "/es" : "/";
      a.href = hash ? `${base}${hash}` : base;
    });
  }

  // Initialise with the current hash if any
  updateLangLinks(window.location.hash);

  function updateActive() {
    let activeId: string | null = null;
    let minTop = Infinity;

    visibleSections.forEach((isVisible, id) => {
      if (isVisible) {
        const top = Math.abs(
          document.getElementById(id)!.getBoundingClientRect().top,
        );
        if (top < minTop) {
          minTop = top;
          activeId = id;
        }
      }
    });

    navLinks.forEach((a) => {
      const isActive =
        activeId !== null && a.getAttribute("data-nav-link") === `#${activeId}`;
      a.classList.toggle("text-red-400", isActive);
      a.classList.toggle("text-slate-400", !isActive);
    });

    updateLangLinks(activeId ? `#${activeId}` : "");
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) =>
        visibleSections.set(entry.target.id, entry.isIntersecting),
      );
      updateActive();
    },
    { rootMargin: "-40% 0px -55% 0px", threshold: 0 },
  );

  sections.forEach((s) => observer.observe(s));

  // Logo: scroll to top without reload when already on the home page
  const logoLink = document.getElementById(
    "navbar-logo-link",
  ) as HTMLAnchorElement | null;
  logoLink?.addEventListener("click", (e) => {
    const href = logoLink.getAttribute("href");
    if (href && window.location.pathname === href) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });
</script>
