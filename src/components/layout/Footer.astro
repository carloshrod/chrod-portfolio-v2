---
import { Image } from "astro:assets";
import Container from "./Container.astro";
import logo from "../../assets/chrod-logo.png";
import Icon from "../ui/icons.astro";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);
const year = new Date().getFullYear();
const homeUrl = lang === "es" ? "/es" : "/";
---

<footer class="border-t border-border bg-[#080808] py-10">
  <Container>
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <a href={homeUrl} id="footer-logo-link" aria-label="Home">
        <Image
          src={logo}
          alt="chrod logo"
          class="h-8 w-auto opacity-60 transition-opacity hover:opacity-100"
        />
      </a>

      <div
        class="flex flex-col items-center gap-1.5 text-center sm:items-start"
      >
        <p class="text-sm text-slate-600">
          &copy; {year} CHRod. {t("footer.rights")}
        </p>
        <div class="flex items-center gap-3 text-xs text-slate-700">
          <a
            href={t("footer.privacy.url")}
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-slate-400"
            >{t("footer.privacy")}</a
          >
          <span aria-hidden="true">·</span>
          <a
            href={t("footer.terms.url")}
            target="_blank"
            rel="noopener noreferrer"
            class="transition-colors hover:text-slate-400"
            >{t("footer.terms")}</a
          >
        </div>
      </div>

      <div class="flex items-center gap-5">
        <a
          href="https://github.com/carloshrod"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="text-slate-600 transition-colors hover:text-red-400"
        >
          <Icon name="github" />
        </a>
        <a
          href="https://www.linkedin.com/in/chrod"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-slate-600 transition-colors hover:text-red-400"
        >
          <Icon name="linkedin" size={20} />
        </a>
      </div>
    </div>
  </Container>
</footer>

<script>
  const footerLogo = document.getElementById(
    "footer-logo-link",
  ) as HTMLAnchorElement | null;
  footerLogo?.addEventListener("click", (e) => {
    const href = footerLogo.getAttribute("href");
    const normalize = (p: string) => p.replace(/\/$/, "") || "/";
    if (href && normalize(window.location.pathname) === normalize(href)) {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: "smooth" });
    }
  });
</script>
