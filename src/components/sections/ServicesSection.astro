---
import Container from "../layout/Container.astro";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);

const services = [
  {
    title: t("services.s1.title"),
    description: t("services.s1.desc"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`,
  },
  {
    title: t("services.s2.title"),
    description: t("services.s2.desc"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: t("services.s3.title"),
    description: t("services.s3.desc"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    title: t("services.s4.title"),
    description: t("services.s4.desc"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>`,
  },
  {
    title: t("services.s5.title"),
    description: t("services.s5.desc"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>`,
  },
  {
    title: t("services.s6.title"),
    description: t("services.s6.desc"),
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  },
];
---

<section id="services" class="py-24">
  <Container>
    <!-- Header -->
    <div class="mb-14 text-center">
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-widest text-red-400"
      >
        {t("services.label")}
      </p>
      <h2 class="mb-4 text-3xl font-bold text-slate-100 sm:text-4xl">
        {t("services.heading")}
      </h2>
      <p class="text-slate-400 leading-relaxed">
        {t("services.subtitle")}
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <div class="group relative rounded-2xl border border-border bg-surface p-7 transition-all duration-300 hover:border-red-600/50 hover:bg-surface/80">
            <!-- Glow on hover -->
            <div
              class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"
              style="background: radial-gradient(circle at top left, rgba(220,38,38,0.07), transparent 70%);"
              aria-hidden="true"
            />

            <!-- Icon -->
            <div class="mb-5 inline-flex items-center justify-center rounded-xl border border-border bg-background p-3 text-red-400 transition-colors duration-300 group-hover:border-red-600/40 group-hover:text-red-300">
              <Fragment set:html={service.icon} />
            </div>

            <!-- Text -->
            <h3 class="mb-2 text-base font-semibold text-slate-100">
              {service.title}
            </h3>
            <p class="text-sm leading-relaxed text-slate-400">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="mt-14 flex flex-col items-center gap-4 text-center">
      <p class="text-slate-400">
        {t("services.cta.text")}
      </p>
      <button
        id="services-contact-btn"
        class="rounded-lg bg-red-600 px-6 py-2.5 text-sm font-semibold text-white transition-all hover:bg-red-500 active:scale-95 cursor-pointer"
      >
        {t("services.cta.button")}
      </button>
    </div>
  </Container>
</section>

<script>
  document
    .getElementById("services-contact-btn")
    ?.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-contact-drawer"));
    });
</script>
