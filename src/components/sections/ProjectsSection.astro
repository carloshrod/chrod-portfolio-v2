---
import Container from "../layout/Container.astro";
import ProjectsGrid from "../ui/ProjectsGrid";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";
import { getProjects } from "../../lib/sanity";

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);

const projects = await getProjects(lang);
---

<section id="projects" class="py-24">
  <Container>
    <div class="mb-14 text-center">
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-widest text-red-400"
      >
        {t("projects.label")}
      </p>
      <h2 class="text-3xl font-bold text-slate-100 sm:text-4xl">
        {t("projects.heading")}
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-slate-400">
        {t("projects.subtitle")}
      </p>
    </div>

    <ProjectsGrid client:load projects={projects} lang={lang} />
  </Container>
</section>
