---
import Container from "../layout/Container.astro";
import SkillBadge from "../ui/SkillBadge.astro";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";
import {
  siJavascript,
  siTypescript,
  siHtml5,
  siCss,
  siReact,
  siNextdotjs,
  siAstro,
  siExpress,
  siTailwindcss,
  siBootstrap,
  siSass,
  siMui,
  siAntdesign,
  siNodedotjs,
  siPostgresql,
  siMysql,
  siMongodb,
  siFirebase,
  siGit,
  siGithub,
  siShopify,
  siN8n,
} from "simple-icons";

function safeColor(hex: string) {
  const r = parseInt(hex.slice(0, 2), 16);
  const g = parseInt(hex.slice(2, 4), 16);
  const b = parseInt(hex.slice(4, 6), 16);
  return (0.299 * r + 0.587 * g + 0.114 * b) / 255 < 0.12 ? "e2e8f0" : hex;
}

const iconMap: Record<string, { path: string; hex: string }> = {
  JavaScript: siJavascript,
  TypeScript: siTypescript,
  HTML5: siHtml5,
  CSS3: siCss,
  React: siReact,
  "Next.js": siNextdotjs,
  Astro: siAstro,
  "Express.js": siExpress,
  "Tailwind CSS": siTailwindcss,
  Bootstrap: siBootstrap,
  "SASS/SCSS": siSass,
  "Ant Design": siAntdesign,
  "Material UI": siMui,
  "Node.js": siNodedotjs,
  PostgreSQL: siPostgresql,
  MySQL: siMysql,
  MongoDB: siMongodb,
  Firebase: siFirebase,
  Git: siGit,
  GitHub: siGithub,
  Shopify: siShopify,
  n8n: siN8n,
};

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);

const skillGroups = [
  {
    category: t("skills.category.languages"),
    skills: ["JavaScript", "TypeScript", "HTML5", "CSS3"],
  },
  {
    category: t("skills.category.frameworks"),
    skills: ["React", "Next.js", "Astro", "Express.js"],
  },
  {
    category: t("skills.category.ui"),
    skills: [
      "Tailwind CSS",
      "Bootstrap",
      "SASS/SCSS",
      "Ant Design",
      "Material UI",
    ],
  },
  {
    category: t("skills.category.backend"),
    skills: ["Node.js", "PostgreSQL", "MySQL", "MongoDB", "Firebase"],
  },
  {
    category: t("skills.category.tools"),
    skills: ["Git", "GitHub", "n8n", "Shopify"],
  },
];
---

<section id="skills" class="relative overflow-hidden bg-surface-alt py-24">
  <!-- Decorative gradient -->
  <div
    class="pointer-events-none absolute right-0 top-1/2 h-125 w-100 -translate-y-1/2 translate-x-1/3"
    aria-hidden="true"
    style="background: radial-gradient(ellipse at center, rgba(220,38,38,0.09) 0%, rgba(220,38,38,0.04) 40%, transparent 70%);"
  >
  </div>
  <Container>
    <div class="mb-14">
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-widest text-red-400"
      >
        {t("skills.label")}
      </p>
      <h2 class="text-3xl font-bold text-slate-100 sm:text-4xl">
        {t("skills.heading")}
      </h2>
    </div>

    <div class="space-y-10">
      {
        skillGroups.map((group) => (
          <div>
            <h3 class="mb-4 text-xs font-semibold uppercase tracking-widest text-slate-600">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-3">
              {group.skills.map((skill) => {
                const icon = iconMap[skill];
                return (
                  <SkillBadge
                    name={skill}
                    iconPath={icon?.path}
                    iconColor={icon ? safeColor(icon.hex) : undefined}
                  />
                );
              })}
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>
