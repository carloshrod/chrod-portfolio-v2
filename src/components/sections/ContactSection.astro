---
import Container from "../layout/Container.astro";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);
---

<section id="contact" class="py-24 bg-surface-alt">
  <Container>
    <div class="mx-auto max-w-2xl text-center">
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-widest text-red-400"
      >
        {t("contact.label")}
      </p>
      <h2 class="mb-4 text-3xl font-bold text-slate-100 sm:text-4xl">
        {t("contact.heading")}
      </h2>
      <p class="mb-8 text-slate-400">
        {t("contact.body")}
      </p>

      <button
        id="contact-section-btn"
        class="rounded-lg bg-red-600 px-8 py-3.5 text-sm font-semibold text-white transition-all hover:bg-red-500 hover:shadow-lg hover:shadow-red-500/25 cursor-pointer"
      >
        {t("contact.button")}
      </button>
    </div>
  </Container>
</section>

<script>
  document
    .getElementById("contact-section-btn")
    ?.addEventListener("click", () => {
      document.dispatchEvent(new CustomEvent("open-contact-drawer"));
    });
</script>
