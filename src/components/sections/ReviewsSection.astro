---
import Container from "../layout/Container.astro";
import ReviewsCarousel from "../ui/ReviewsCarousel.tsx";
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";
import { getReviews } from "../../lib/sanity";

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);

const reviews = await getReviews(lang);
---

<section id="reviews" class="py-24 bg-surface-alt overflow-hidden">
  <Container>
    <div class="mb-14 text-center">
      <p
        class="mb-3 text-sm font-semibold uppercase tracking-widest text-red-400"
      >
        {t("reviews.label")}
      </p>
      <h2 class="text-3xl font-bold text-slate-100 sm:text-4xl">
        {t("reviews.heading")}
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-slate-400">
        {t("reviews.subtitle")}
      </p>
    </div>
  </Container>

  <!-- Carousel spans full width, outside the container -->
  <div class="relative mt-4">
    <!-- Fade edges -->
    <div
      class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-linear-to-r from-surface-alt to-transparent"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-linear-to-l from-surface-alt to-transparent"
    >
    </div>

    <div class="px-6">
      <ReviewsCarousel reviews={reviews} client:visible />
    </div>
  </div>
</section>
