---
import { useTranslations } from "../../i18n/utils";
import type { Locale } from "../../i18n/ui";
import Icon from "./icons.astro";

const { lang = "en" } = Astro.props as { lang?: Locale };
const t = useTranslations(lang);
---

<a
  id="whatsapp-btn"
  href="https://wa.me/573127600792"
  target="_blank"
  rel="noopener noreferrer"
  aria-label={t("whatsapp.label")}
  class="group fixed bottom-6 right-6 z-80 flex h-14 w-14 items-center justify-center rounded-full bg-surface ring-1 ring-border shadow-lg shadow-black/50 transition-all duration-300 hover:scale-110 hover:bg-surface-raised hover:ring-border-muted"
>
  <Icon name="whatsapp" />
</a>

<style>
  @keyframes wa-wiggle {
    0% {
      transform: scale(1) rotate(0deg);
    }
    20% {
      transform: scale(1.28) rotate(-8deg);
    }
    40% {
      transform: scale(1.28) rotate(8deg);
    }
    60% {
      transform: scale(1.18) rotate(-5deg);
    }
    80% {
      transform: scale(1.18) rotate(5deg);
    }
    100% {
      transform: scale(1) rotate(0deg);
    }
  }
  .wa-animate {
    animation: wa-wiggle 0.55s ease-in-out;
  }
</style>

<script>
  const waBtn = document.getElementById("whatsapp-btn");

  function triggerWiggle() {
    if (!waBtn) return;
    waBtn.classList.remove("wa-animate");
    void (waBtn as HTMLElement).offsetWidth; // reflow para reiniciar animación
    waBtn.classList.add("wa-animate");
    waBtn.addEventListener(
      "animationend",
      () => waBtn.classList.remove("wa-animate"),
      { once: true },
    );
  }

  const ctaIds = [
    "hero-contact-btn",
    "services-contact-btn",
    "contact-section-btn",
    "navbar-contact-btn",
    "mobile-contact-btn",
    "contact-form-btn",
  ];

  ctaIds.forEach((id) => {
    const el = document.getElementById(id);
    el?.addEventListener("mouseenter", triggerWiggle);
    el?.addEventListener("click", triggerWiggle);
  });
</script>
